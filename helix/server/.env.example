# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Database (Supabase Postgres connection string, pgvector extension enabled)
DATABASE_URL=postgresql://user:password@host:5432/postgres?schema=public

# Google Gemini (LLM + embeddings) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional override — defaults try gemini-flash-latest then flash-lite-latest
# (avoids free-tier 20/day caps on gemini-2.5-flash alone).
# GEMINI_MODEL=gemini-flash-latest

# Cloudinary (original file storage) — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Telegram Bot (optional — zero-effort capture channel)
TELEGRAM_BOT_TOKEN=

# GitHub (optional — connects a user's repos as skill evidence)
GITHUB_TOKEN=

# Email forwarding (optional — zero-effort capture channel; forward a
# certificate/offer email to this inbox from the address you registered with).
# Use an app password, not your normal account password.
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
